{
  "name": "zenny",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "mobile": "yarn workspace zenny-mobile start",
    "api": "yarn workspace zenny-api dev",
    "api:seed": "yarn workspace zenny-api prisma:seed",
    "api:migrate": "yarn workspace zenny-api prisma:migrate",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "setup": "yarn install && yarn docker:up && yarn api:migrate && yarn api:seed"
  },
  "devDependencies": {
    "typescript": "~5.3.3"
  }
}